<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="RunixLauncher.Controls.Modals.Modal_MultiSelect">
  <Border VerticalAlignment="Center" HorizontalAlignment="Center" Width="400" MaxHeight="800" Background="#0f1419" CornerRadius="16" ClipToBounds="True" BorderBrush="#1b1f24" BorderThickness="1">
    <Grid RowDefinitions="30, 5, *" Margin="10">
      <Label x:Name="lbl_Title" Grid.Row="0" Content="Title" HorizontalAlignment="Center" FontSize = "18"/>

      <StackPanel Grid.Row="2" Spacing="5" HorizontalAlignment="Stretch" x:Name="btns" />
    </Grid>
  </Border>
</UserControl>
