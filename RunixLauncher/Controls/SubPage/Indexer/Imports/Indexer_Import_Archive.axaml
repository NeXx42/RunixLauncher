<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="RunixLauncher.Controls.SubPage.Indexer.Imports.Indexer_Import_Archive"
  xmlns:Common="clr-namespace:RunixLauncher.Controls">
  <Border Background="#0a0e13" CornerRadius="5" BorderBrush="{DynamicResource bg_Border}" BorderThickness="1">
    <StackPanel Margin="5" Spacing="5">
      <Border Height="30">
        <Grid>
          <Label x:Name="lbl_Extract" VerticalAlignment="Center" Content="ARCHOVE"/>
          <Common:Common_Button x:Name="btn_Extract" HorizontalAlignment="Right" Width="150" Label="Extract" Margin="0 0 105 0"/>
          <Common:Common_Button x:Name="btn_Remove" Label="Remove" Classes="negative" HorizontalAlignment="Right" Width="100"/>
        </Grid>
      </Border>
      <Border Height="30">
        <Grid>
          <Label VerticalAlignment="Center" x:Name="lbl_Folder" Grid.Column="0"/>
          <ProgressBar VerticalAlignment="Stretch" Grid.Column="0" Minimum="0" Maximum="100" Value="0" ShowProgressText="True" x:Name="inp_ProgressBar"/>

          <Common:Common_Button x:Name="btn_Explore" Grid.Column="2" Width="150" HorizontalAlignment="Right" Label="Explore" />
        </Grid>
      </Border>
    </StackPanel>
  </Border>
</UserControl>
