<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="RunixLauncher.Controls.SubPage.Indexer.Imports.Indexer_Import_Folder"
  xmlns:Common="clr-namespace:RunixLauncher.Controls">
  <Border Background="#0a0e13" CornerRadius="5" BorderBrush="{DynamicResource bg_Border}" BorderThickness="1">
    <StackPanel Margin="5" Spacing="5">
      <Grid Height="30">
        <Label x:Name="lbl_Path" VerticalAlignment="Center" Content="ARCHOVE"/>
        <Common:Common_Button x:Name="btn_Remove" Label="Remove" Classes="negative" Width="100" HorizontalAlignment="Right"/>
      </Grid>

      <Common:Common_Dropdown x:Name="inp_Binaries"/>
    </StackPanel>
  </Border>
</UserControl>
