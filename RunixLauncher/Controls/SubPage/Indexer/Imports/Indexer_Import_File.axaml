<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="RunixLauncher.Controls.SubPage.Indexer.Imports.Indexer_Import_File">
  <Border Background="Green" CornerRadius="5">
    <Label x:Name="lbl_Path" VerticalAlignment="Center" Content="ARCHOVE"/>
  </Border>
</UserControl>
