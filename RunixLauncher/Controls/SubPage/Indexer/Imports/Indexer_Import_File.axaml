<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="RunixLauncher.Controls.SubPage.Indexer.Imports.Indexer_Import_File"
  xmlns:Common="clr-namespace:RunixLauncher.Controls">
  <Border Background="#0a0e13" CornerRadius="5" BorderBrush="{DynamicResource bg_Border}" BorderThickness="1">
    <Grid Margin="5" Height="30">
      <Label x:Name="lbl_Path" VerticalAlignment="Center" Content="ARCHOVE"/>
      <Common:Common_Button x:Name="btn_Remove" Label="Remove" Classes="negative" HorizontalAlignment="Right" Width="100"/>
    </Grid>
  </Border>
</UserControl>
