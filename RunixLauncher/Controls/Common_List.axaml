<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="RunixLauncher.Controls.Common_List"
  xmlns:Controls="clr-namespace:RunixLauncher.Controls"
  xmlns:local="clr-namespace:RunixLauncher.Controls" x:DataType="local:Common_List">
  <Border CornerRadius="5" Background="#0f1419" BorderBrush="#1b1f24" BorderThickness="1">
    <Grid Margin="5" RowDefinitions="Auto * 30">
      <Label Content="{Binding Label, Mode=OneWay}"/>

      <StackPanel x:Name="container" Grid.Row="1"/>

      <Grid Grid.Row="2" Height="30" Margin="0,10,0,0">
        <Controls:Common_Button Classes="negative" x:Name="btn_Remove" Width="150" Label="Delete" HorizontalAlignment="Left"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Controls:Common_Button x:Name="btn_Add" Width="150" Label="Add"/>
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</UserControl>
